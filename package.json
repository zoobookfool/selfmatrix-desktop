{
  "name": "selfmatrix-desktop",
  "productName": "SelfMatrix",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "description": "SelfMatrix native desktop shell (Electron) embedding cinny + Element Call.",
  "repository": {
    "type": "git",
    "url": "github:zoobookfool/selfmatrix-desktop"
  },
  "main": "src/main.cjs",
  "scripts": {
    "start": "electron src/main.cjs",
    "harness": "electron src/main.cjs --harness",
    "smoke": "electron src/main.cjs --smoke --harness",
    "memory": "electron src/main.cjs --memory-probe --harness",
    "cinny-shell": "electron src/main.cjs --cinny-shell",
    "cinny-shell-smoke": "electron src/main.cjs --cinny-shell-smoke",
    "tray-probe": "electron src/main.cjs --tray-probe",
    "minisign-probe": "electron src/main.cjs --minisign-probe",
    "probe:source-picker-selection": "node src/source-picker-selection-probe.cjs",
    "probe:minisign-verify": "node src/minisign-verify-probe.cjs",
    "probe:update-signature-verify": "node src/update-signature-verify-probe.cjs",
    "test": "npm run smoke && npm run memory && npm run cinny-shell-smoke && npm run tray-probe && npm run minisign-probe && npm run probe:source-picker-selection && npm run probe:minisign-verify && npm run probe:update-signature-verify",
    "probe:system-audio": "electron src/system-audio-probe.cjs",
    "probe:app-audio-capture": "electron src/app-audio-capture-probe.cjs",
    "e2e:join": "node e2e/native-join.e2e.mjs",
    "e2e:callflow": "node e2e/native-callflow.e2e.mjs"
  },
  "devDependencies": {
    "electron": "43.0.0"
  },
  "dependencies": {
    "matrix-widget-api": "1.16.1"
  }
}
